# Copy to `.env` for local development. Do not commit `.env`.
# Vite exposes only variables prefixed with VITE_ to the browser bundle.
# Set production/preview values in the Vercel project Environment Variables UI.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key-here

# Staff admin (`/jeremy-admin/login`): enabled automatically during `npm run dev`.
# For production / preview builds, set exactly:
# VITE_ADMIN_PORTAL_ENABLED=true

# Optional: custom staff URL prefix (also applies in dev).
# Example: VITE_ADMIN_BASE_PATH=/ops-7a2f9c
# VITE_ADMIN_BASE_PATH=/jeremy-admin

# Optional: comma-separated emails allowed to use the staff sign-in form (RLS still requires admin role).
# VITE_ADMIN_ALLOWED_EMAILS=you@company.com

# Stripe test publishable key for the React checkout UI (never put secret keys in VITE_ vars).
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Optional override for the payment API (defaults to /api via the Vite dev proxy).
# VITE_PAYMENTS_API_URL=http://localhost:4242/api
