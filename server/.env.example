# Copy to `server/.env` for local payment API development. Do not commit `server/.env`.
# Set production values in Vercel (serverless/Node) or your host's secret store.

PORT=4242
CLIENT_ORIGIN=http://localhost:5173

STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key-here

# Optional: required for Stripe webhook order updates (server only; never expose to the client).
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
